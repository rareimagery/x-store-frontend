# RareImagery Production Environment — VPS Self-Hosted
# Copy to /var/www/rareimagery/.env.production and fill in values

# --- Required ---
NEXTAUTH_URL=https://www.rareimagery.net
NEXTAUTH_SECRET=<generate-with: openssl rand -base64 32>
DRUPAL_API_URL=http://127.0.0.1
DRUPAL_API_USER=rare
DRUPAL_API_PASS=<drupal-api-password>

# --- X (Twitter) OAuth ---
X_CLIENT_ID=<from-developer.x.com>
X_CLIENT_SECRET=<from-developer.x.com>
X_API_BEARER_TOKEN=<app-only-bearer-token>

# --- Grok AI (xAI) ---
XAI_API_KEY=<from-console.x.ai>

# --- Social OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Email (Brevo SMTP) ---
SMTP_HOST=smtp-relay.brevo.com
SMTP_USER=
SMTP_PASS=

# --- Cron ---
CRON_SECRET=<random-string-for-cron-auth>

# --- Platform ---
NEXT_PUBLIC_BASE_DOMAIN=rareimagery.net
ADMIN_X_USERNAMES=rareimagery
CONSOLE_ADMIN_EMAIL=<admin-email>
CONSOLE_ADMIN_PASSWORD=<admin-password>

# --- Optional ---
CLOUDFLARE_API_TOKEN=
TELNYX_API_KEY=
GROK_API_KEY=
PRINTFUL_API_KEY=

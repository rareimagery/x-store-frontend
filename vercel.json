{
  "crons": [
    {
      "path": "/api/cron/frontend-agent",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/site-generate-agent",
      "schedule": "0 */5 * * *"
    },
    {
      "path": "/api/cron/drupal-api-path-agent",
      "schedule": "0 */5 * * *"
    },
    {
      "path": "/api/cron/api-agent",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/x-money-watcher",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/code-audit",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/wiki-sync",
      "schedule": "0 */8 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/auth/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/:creator/store",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/stores/:creator",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/((?!api/auth|.*/store|stores/).*)",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=60, stale-while-revalidate=300" }
      ]
    }
  ]
}
